 test_df):\n    print(\"Preprocessing and Feature Engineering...\")\n    \n    # --- FIX STARTS HERE ---\n    # Map target strings to integers: Absence -> 0, Presence -> 1\n    target_map = {'Absence': 0, 'Presence': 1}\n    \n    # Check if mapping is needed (in case data is already 0/1)\n    if train_df[CONFIG['target_col']].dtype == 'object':\n        print(f\"Mapping target column: {target_map}\")\n        train_df[CONFIG['target_col']] = train_df[CONFIG['target_col']].map(target_map)\n    # --- FIX ENDS HERE ---\n\n    # Separate target\n    y = train_df[CONFIG['target_col']]\n    train_df = train_df.drop(columns=[CONFIG['target_col']])\n    \n    # Combine for consistent processing\n    combined = pd.concat([train_df, test_df], axis=0).reset_index(drop=True)\n    \n    # Apply Feature Engineering\n    combined = feature_engineering(combined)\n    \n    # Drop ID column from features\n    if CONFIG['id_col'] in combined.columns:\n        combined = combined.drop(columns=[CONFIG['id_col']])\n    \n    # Auto-identify columns\n    cat_cols = [c for c in combined.columns if combined[c].dtype == 'object' or combined[c].nunique() < 10]\n    \n    # Label Encoding for Categoricals\n    for col in cat_cols:\n        le = LabelEncoder()\n        combined[col] = le.fit_transform(combined[col].astype(str))\n        combined[col] = combined[col].astype('category')\n\n    # Split back\n    X = combined.iloc[:len(train_df)].reset_index(drop=True)\n    X_test = combined.iloc[len(train_df):].reset_index(drop=True)\n    \n    return X, y, X_test, cat_cols\n\ndef train_and_evaluate(X, y, X_test, cat_features):\n    skf = StratifiedKFold(n_splits=CONFIG['n_folds'], shuffle=True, random_state=CONFIG['seed'])\n    \n    oof_preds = np.zeros(len(X))\n    test_preds = np.zeros(len(X_test))\n    \n    # Weights for ensemble\n    weights = {'xgb': 0.34, 'lgbm': 0.33, 'cat': 0.33}\n    scores = []\n    \n    print(f\"\\nStarting Training with {CONFIG['n_folds']} folds...\")\n    \n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        X_train, X_val = X.iloc[train_idx], X.iloc[val_idx]\n        y_train, y_val = y.iloc[train_idx], y.iloc[val_idx]\n        \n        # 1. XGBoost\n        xgb_model = XGBClassifier(\n            n_estimators=1000,\n            learning_rate=0.03,\n            max_depth=6,\n            enable_categorical=True,\n            eval_metric='auc',\n            random_state=CONFIG['seed'] + fold,\n            early_stopping_rounds=50,\n            verbosity=0\n        )\n        xgb_model.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=False)\n        p_xgb = xgb_model.predict_proba(X_val)[:, 1]\n        t_xgb = xgb_model.predict_proba(X_test)[:, 1]\n\n        # 2. LightGBM\n        lgbm_model = LGBMClassifier(\n            n_estimators=1000,\n            learning_rate=0.03,\n            metric='auc',\n            random_state=CONFIG['seed'] + fold,\n            verbosity=-1\n        )\n        lgbm_model.fit(X_train, y_train, eval_set=[(X_val, y_val)])\n        p_lgbm = lgbm_model.predict_proba(X_val)[:, 1]\n        t_lgbm = lgbm_model.predict_proba(X_test)[:, 1]\n\n        # 3. CatBoost\n        cat_model = CatBoostClassifier(\n            iterations=1000,\n            learning_rate=0.03,\n            eval_metric='AUC',\n            random_seed=CONFIG['seed'] + fold,\n            verbose=False,\n            allow_writing_files=False,\n            cat_features=cat_features\n        )\n        cat_model.fit(X_train, y_train, eval_set=(X_val, y_val), early_stopping_rounds=50)\n        p_cat = cat_model.predict_proba(X_val)[:, 1]\n        t_cat = cat_model.predict_proba(X_test)[:, 1]\n\n        # Weighted Ensemble\n        fold_pred = (p_xgb * weights['xgb']) + (p_lgbm * weights['lgbm']) + (p_cat * weights['cat'])\n        fold_test_pred = (t_xgb * weights['xgb']) + (t_lgbm * weights['lgbm']) + (t_cat * weights['cat'])\n        \n        oof_preds[val_idx] = fold_pred\n        test_preds += fold_test_pred / CONFIG['n_folds']\n        \n        auc = roc_auc_score(y_val, fold_pred)\n        scores.append(auc)\n        print(f\"Fold {fold+1} AUC: {auc:.5f}\")\n\n    print(f\"\\nOverall CV AUC: {roc_auc_score(y, oof_preds):.5f}\")\n    return test_preds\n\ndef main():\n    train, test, submission = load_data(CONFIG['input_dir'])\n    X, y, X_test, cat_cols = preprocess(train, test)\n    predictions = train_and_evaluate(X, y, X_test, cat_cols)\n    \n    # Save submission\n    submission[CONFIG['target_col']] = predictions\n    submission.to_csv('submission.csv', index=False)\n    print(\"\\nSuccess! submission.csv created.\")\n    print(submission.head())\n\nif __name__ == \"__main__\":\n    main()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-28T11:29:07.644233Z","iopub.execute_input":"2026-02-28T11:29:07.644475Z","iopub.status.idle":"2026-02-28T12:27:45.493667Z","shell.execute_reply.started":"2026-02-28T11:29:07.644456Z","shell.execute_reply":"2026-02-28T12:27:45.492746Z"}},"outputs":[],"execution_count":null}]}